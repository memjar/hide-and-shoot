{
  "name": "hide-and-shoot",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "cd client && npx vite --host",
    "build": "cd client && npx vite build",
    "start": "node server/index.js"
  },
  "dependencies": {
    "express": "^4.21.0",
    "socket.io": "^4.8.0",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
